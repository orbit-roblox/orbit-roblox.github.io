toggleBtn.MouseButton1Click:Connect(function()
    scriptEnabled = not scriptEnabled
    if scriptEnabled then
        toggleBtn.TextColor3 = GREEN
        toggleBtn.Text       = "▶  Script: ON"
        local s = toggleBtn:FindFirstChildOfClass("UIStroke")
        if s then s.Color = PURPLE2 end
        TweenService:Create(statusDot, TweenInfo.new(0.2), {BackgroundColor3 = GREEN}):Play()
        statusText.Text       = "Script Active"
        statusText.TextColor3 = GREEN
    else
        toggleBtn.TextColor3 = RED
        toggleBtn.Text       = "⏹  Script: OFF"
        local s = toggleBtn:FindFirstChildOfClass("UIStroke")
        if s then s.Color = LGREY end
        TweenService:Create(statusDot, TweenInfo.new(0.2), {BackgroundColor3 = RED}):Play()
        statusText.Text       = "Script Inactive"
        statusText.TextColor3 = TXLO
    end
    for _, overlay in pairs(hookedButtons) do
        if overlay and overlay.Parent then overlay.Visible = scriptEnabled end
    end
end)

balanceInput.FocusLost:Connect(function()
    local num = tonumber(balanceInput.Text)
    if num then currentBalance = num
    else balanceInput.Text = tostring(currentBalance) end
end)

giftInput.FocusLost:Connect(function()
    local name = giftInput.Text
    if name and name ~= "" then giftTarget = name
    else giftInput.Text = giftTarget end
end)

