local function buildWaveGradient(parent, rot)
    local g    = Instance.new("UIGradient")
    g.Rotation = rot or 45
    g.Parent   = parent
    return g
end

-- Chromewave: sharp bright peaks of vivid purple/violet/indigo/magenta
-- surrounded by deep black troughs — like light reflecting off chrome
local WAVE_STOPS = {
    Color3.fromRGB(  0,   0,   0),  -- [1] pure black
    Color3.fromRGB(  8,   0,  18),  -- [2] near-black indigo
    Color3.fromRGB( 22,   2,  48),  -- [3] very dark violet
    Color3.fromRGB( 55,   5, 115),  -- [4] deep purple
    Color3.fromRGB(110,  20, 210),  -- [5] vivid purple PEAK 1
    Color3.fromRGB( 80,  10, 160),  -- [6] mid purple
    Color3.fromRGB( 30,   3,  70),  -- [7] dark purple
    Color3.fromRGB(  5,   0,  14),  -- [8] near-black
    Color3.fromRGB(  0,   0,   0),  -- [9] black trough
    Color3.fromRGB(  6,   0,  20),  -- [10] near-black blue-indigo
    Color3.fromRGB( 18,   4,  55),  -- [11] deep indigo
    Color3.fromRGB( 50,  15, 130),  -- [12] indigo-purple
    Color3.fromRGB( 85,  35, 200),  -- [13] blue-violet PEAK 2
    Color3.fromRGB(120,  20, 220),  -- [14] vivid violet (brightest)
    Color3.fromRGB( 75,   8, 155),  -- [15] cool purple
    Color3.fromRGB( 35,   3,  75),  -- [16] dark violet
    Color3.fromRGB(  8,   0,  20),  -- [17] near-black
    Color3.fromRGB(  0,   0,   0),  -- [18] black trough
    Color3.fromRGB( 10,   0,  22),  -- [19] near-black magenta-purple
    Color3.fromRGB( 35,   5,  70),  -- [20] dark magenta-purple
    Color3.fromRGB( 80,  15, 145),  -- [21] magenta-purple
    Color3.fromRGB(130,  25, 190),  -- [22] magenta-violet PEAK 3
    Color3.fromRGB( 90,  12, 160),  -- [23] cool magenta
    Color3.fromRGB( 40,   4,  88),  -- [24] deep cool purple
    Color3.fromRGB( 12,   1,  28),  -- [25] near-black
    Color3.fromRGB(  0,   0,   0),  -- [26] black — back to start
}
local WAVE_N = #WAVE_STOPS - 1

local function getWaveSequence(shift)
    local kp = {}
    local N  = 32
    for i = 0, N do
        local x     = i / N
        local phase = ((x - shift) % 1 + 1) % 1
        local fi    = phase * WAVE_N
        local lo    = math.floor(fi)
        local hi    = math.min(lo + 1, WAVE_N)
        local t     = fi - lo
        -- ease through peaks with smoothstep for chrome sharpness
        t = t * t * (3 - 2 * t)
        local c = WAVE_STOPS[lo + 1]:Lerp(WAVE_STOPS[hi + 1], t)
        table.insert(kp, ColorSequenceKeypoint.new(math.min(x, 1), c))
    end
    return ColorSequence.new(kp)
end

