-- ==========================================
-- HELPERS
-- ==========================================
local function corner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 6)
    c.Parent = p
end

local function outline(p, col, thick)
    local s = Instance.new("UIStroke")
    s.Color           = col or LGREY
    s.Thickness       = thick or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent          = p
    return s
end

local function listLayout(p, spacing)
    local l = Instance.new("UIListLayout")
    l.Padding             = UDim.new(0, spacing or 5)
    l.HorizontalAlignment = Enum.HorizontalAlignment.Center
    l.SortOrder           = Enum.SortOrder.LayoutOrder
    l.Parent              = p
end

local function pad(p, t, b, l, r)
    local u = Instance.new("UIPadding")
    u.PaddingTop    = UDim.new(0, t or 6)
    u.PaddingBottom = UDim.new(0, b or 6)
    u.PaddingLeft   = UDim.new(0, l or 6)
    u.PaddingRight  = UDim.new(0, r or 6)
    u.Parent = p
end

local function label(parent, txt, size, col, xalign, zidx)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.Text                   = txt
    l.Font                   = Enum.Font.GothamSemibold
    l.TextSize               = size or 11
    l.TextColor3             = col or WHITE
    l.TextXAlignment         = xalign or Enum.TextXAlignment.Left
    l.ZIndex                 = zidx or 2
    l.Parent                 = parent
    return l
end

-- ==========================================
-- DRAG
-- ==========================================
local function makeDraggable(handle, target)
    local dragging, dragInput, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            dragging  = true
            dragStart = input.Position
            startPos  = target.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    handle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local d = input.Position - dragStart
            target.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + d.X,
                startPos.Y.Scale, startPos.Y.Offset + d.Y
            )
        end
    end)
end

