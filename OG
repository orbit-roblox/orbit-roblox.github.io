        end
    end
end)

local function startBinding(target, btn)
    if isBinding and bindingBtn and bindingBtn ~= btn then
        bindingBtn.Text      = (bindingTarget == "UI" and uiKeybind or masterKeybind).Name
        bindingBtn.TextColor3 = PURPLE
    end
    isBinding     = true
    bindingTarget = target
    bindingBtn    = btn
    btn.Text      = "[ press key... ]"
    btn.TextColor3 = TXLO
end

UIKeyBtn.MouseButton1Click:Connect(function() startBinding("UI", UIKeyBtn) end)
MasterKeyBtn.MouseButton1Click:Connect(function() startBinding("Master", MasterKeyBtn) end)

UserInputService.InputBegan:Connect(function(input, gp)
    if isBinding and input.UserInputType == Enum.UserInputType.Keyboard then
        if bindingTarget == "UI" then
            uiKeybind          = input.KeyCode
            UIKeyBtn.Text      = uiKeybind.Name
            UIKeyBtn.TextColor3 = PURPLE
        elseif bindingTarget == "Master" then
            masterKeybind          = input.KeyCode
            MasterKeyBtn.Text      = masterKeybind.Name
            MasterKeyBtn.TextColor3 = PURPLE
        end
        isBinding     = false
        bindingTarget = nil
        bindingBtn    = nil
    elseif not gp and not isBinding then
        if input.KeyCode == uiKeybind    then toggleMinimize() end
        if input.KeyCode == masterKeybind then toggleMaster()  end
    end
end)

-- ==========================================
-- RENDER LOOP
-- ==========================================
RunService.RenderStepped:Connect(function()
    if not isMasterEnabled then return end
    local shift  = (os.clock() * 0.4) % 0.85
    local ogSeq  = getOGSequence(shift)
    local secSeq = getSecretSequence(shift)
    for i = #activeGradients, 1, -1 do
        local g = activeGradients[i]
        if g and g.Parent then g.Color = ogSeq
        else table.remove(activeGradients, i) end
    end
    for i = #secretGradients, 1, -1 do
        local g = secretGradients[i]
        if g and g.Parent then g.Color = secSeq
        else table.remove(secretGradients, i) end
    end
end)

task.spawn(function()
    while task.wait(2) do applyOG() end
end)
