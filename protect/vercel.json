{
  "version": 2,
  "public": true,
  "buildCommand": null,
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/api/store",
      "dest": "/api/store.js"
    },
    {
      "src": "/api/([a-z0-9]{8})",
      "dest": "/api/[id].js?id=$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
