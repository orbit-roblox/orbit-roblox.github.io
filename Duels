local _t, _sy = 0, -4.0
RunService.Heartbeat:Connect(function(dt)
    _t  = _t + dt
    _sy = _sy + 48*dt
    if _sy > H+5 then _sy = -4 end
    for _, s in ipairs(stars) do
        s.x=s.x+s.vx; s.y=s.y+s.vy
        if s.x>W+3 then s.x=-3 elseif s.x<-3 then s.x=W+3 end
        if s.y>H+3 then s.y=-3 elseif s.y<-3 then s.y=H+3 end
        s.f.Position = UDim2.new(0,s.x,0,s.y)
        s.f.BackgroundTransparency = math.clamp(s.base+math.sin(_t*s.ts+s.ph)*0.2,0.05,0.95)
    end
    Scan.Position             = UDim2.new(0,0,0,_sy)
    Scan.BackgroundTransparency = 0.87+math.sin(_t*2.8)*0.07
    TitleLbl.TextColor3       = C.Iris:Lerp(Color3.fromRGB(230,190,255),0.5+math.sin(_t*0.9)*0.5)
end)

RunService.RenderStepped:Connect(function(dt)
    local fps  = math.floor(1/dt)
    local ping = 0
    pcall(function() ping=math.floor(Stats_s.Network.ServerStatsItem["Data Ping"]:GetValue()) end)
    IslandLbl.Text = "FPS: "..fps.." | PING: "..ping.."ms"
end)

