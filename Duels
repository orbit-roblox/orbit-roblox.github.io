-- Steal Paths
local stealPathActive  = false
local stealLastFlatVel = Vector3.zero
local SP_FAST      = 59.2
local SP_SLOW      = 29.6
local SP_STOP_BASE = 1.35
local SP_STOP_MIN  = 0.65
local SP_BIAS      = 0.45
local SP_SMOOTH    = 0.12

local stealPath_Right = {
    {pos=Vector3.new(-470.6,-5.9,34.4)},
    {pos=Vector3.new(-484.2,-3.9,21.4)},
    {pos=Vector3.new(-475.6,-5.8,29.3)},
    {pos=Vector3.new(-473.4,-5.9,111)}
}
local stealPath_Left = {
    {pos=Vector3.new(-474.7,-5.9,91.0)},
    {pos=Vector3.new(-483.4,-3.9,97.3)},
    {pos=Vector3.new(-474.7,-5.9,91.0)},
    {pos=Vector3.new(-476.1,-5.5,25.4)}
}
local function stealMoveToPoint(hrp, cur, nxt, spd)
    local conn
    conn = RunService.Heartbeat:Connect(function()
        if not stealPathActive then conn:Disconnect(); hrp.AssemblyLinearVelocity=Vector3.zero; return end
        local pos    = hrp.Position
        local target = Vector3.new(cur.X,pos.Y,cur.Z)
        local dir    = target - pos
        local dist   = dir.Magnitude
        local stopD  = math.clamp(SP_STOP_BASE-dist*0.04, SP_STOP_MIN, SP_STOP_BASE)
        if dist <= stopD then conn:Disconnect(); hrp.AssemblyLinearVelocity=Vector3.zero; return end
        local md = dir.Unit
        if nxt then
            local nd = (Vector3.new(nxt.X,pos.Y,nxt.Z)-pos).Unit
            md = (md + nd*SP_BIAS).Unit
        end
        if stealLastFlatVel.Magnitude > 0.1 then
            md = (md*(1-SP_SMOOTH) + stealLastFlatVel.Unit*SP_SMOOTH).Unit
        end
        local vel = Vector3.new(md.X*spd, hrp.AssemblyLinearVelocity.Y, md.Z*spd)
        hrp.AssemblyLinearVelocity = vel
        stealLastFlatVel = Vector3.new(vel.X,0,vel.Z)
    end)
    while stealPathActive and
        (Vector3.new(hrp.Position.X,0,hrp.Position.Z)-Vector3.new(cur.X,0,cur.Z)).Magnitude > SP_STOP_BASE do
        RunService.Heartbeat:Wait()
    end
end
local function stealRunPath(path)
    local hrp = (Player.Character or Player.CharacterAdded:Wait()):WaitForChild("HumanoidRootPart")
    for i, p in ipairs(path) do
        if not stealPathActive then return end
        local spd  = i>2 and SP_SLOW or SP_FAST
        local nxtP = path[i+1] and path[i+1].pos
        stealMoveToPoint(hrp, p.pos, nxtP, spd)
        if i==2 then task.wait(0.2) else task.wait(0.01) end
    end
end
local function startStealPath(path)
    stealPathActive = true
    task.spawn(function()
        while stealPathActive do stealRunPath(path); task.wait(0.1) end
    end)
end
local function stopStealPath()
    stealPathActive = false
    local hrp = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.AssemblyLinearVelocity = Vector3.zero end
end

